---
import "material-symbols/outlined.css";
import { ClientRouter } from "astro:transitions";
import LoadingIndicator from "astro-loading-indicator/component";
import { twMerge } from "tailwind-merge";
import { readSingleton } from "@directus/sdk";

import "@/styles/global.css";
import { Toaster } from "@/components/ui/sonner";
import Sidebar from "@/components/layouts/Sidebar";
import Topbar from "@/components/layouts/Topbar";
import SessionManager from "@/components/layouts/SessionManager";
import { directus } from "@/utils/directus";
import Logo from "@/astros/Logo.astro";
import LayoutConfig from "@/astros/LayoutConfig.astro";
import EnvWarning from "@/astros/EnvWarning.astro";

const url = Astro.url.pathname;

interface Props {
  className?: string;
}

const { className } = Astro.props;

let siteTitle = "EMOBase";

try {
  const siteInfo = await directus.request(readSingleton("site_info"));
  if (siteInfo.title) {
    siteTitle = siteInfo.title;
  }
} catch (err) {
  console.error(" Error fetching site info:", err);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Noto+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <LayoutConfig />

    <ClientRouter />
    <LoadingIndicator color="var(--primary)" />
  </head>
  <body class="h-screen w-full overflow-hidden flex flex-col">
    <EnvWarning />
    <div class="flex-1 flex overflow-hidden">
      <SessionManager client:load transition:persist />
      <Toaster client:load transition:persist />
      <Sidebar url={url} title={siteTitle} client:load transition:persist>
        <Logo slot="logo" />
      </Sidebar>
      <div class="flex-1 flex flex-col">
        <Topbar client:load transition:persist />
        <main
          class={twMerge(
            "flex-1 overflow-y-auto scroll-smooth p-6 md:p-10 scroll-p-6 md:scroll-p-10",
            className,
          )}
        >
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>

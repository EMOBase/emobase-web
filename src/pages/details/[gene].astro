---
import { readItems } from "@directus/sdk";

import Layout from "@/layouts/default.astro";
import geneService from "@/utils/services/geneService";
import phenotypeService from "@/utils/services/phenotypeService";
import goAnnotationService from "@/utils/services/goAnnotationService";
import ontologyService from "@/utils/services/ontologyService";
import { directus } from "@/utils/directus";
import GeneDetails, {
  type GeneLinkTemplate,
} from "@/components/pages/details/GeneDetails";
import GeneNotFound from "@/components/pages/details/GeneNotFound";
import JBrowseGenomeView from "@/components/pages/details/GenomeBrowser/JBrowseGenomeView";

const { fetchIBs, fetchTriboliumGenes, fetchOrthology, fetchDrosophilaGenes } =
  geneService();
const { fetchByGene: fetchPhenotypesByGene } = phenotypeService();
const { fetchByGenes: fetchGOByGenes } = goAnnotationService();
const { fetchByIds: fetchTermsByIds } = ontologyService("GO");

const { gene = "" } = Astro.params;

const triboliumGene = (await fetchTriboliumGenes([gene]))[0];
const dsRNAs = await fetchIBs(gene);
const phenotypes = await fetchPhenotypesByGene(gene);

const orthology = await fetchOrthology(gene);
const orthologySources = (orthology.orthologs || []).reduce(
  (acc, o) => {
    if (o.source) {
      acc[o.gene] = [o.source, ...(acc[o.gene] || [])];
    }
    return acc;
  },
  {} as Record<string, string[]>,
);

const orthologousGenes = Object.entries(orthologySources)
  .sort(([, a], [, b]) => b.length - a.length)
  .map(([gene]) => gene);
const anns = await fetchGOByGenes(orthologousGenes);
const missingNames = new Set(
  anns.filter((a) => !a.term.name).map((a) => a.term.id),
);
if (missingNames.size > 0) {
  const terms = await fetchTermsByIds(Array.from(missingNames));
  const termMap = new Map(terms.map((t) => [t.id, t.name]));
  anns.forEach((a) => {
    if (!a.term.name) {
      a.term.name = termMap.get(a.term.id) || "";
    }
  });
}
const annsById = anns.reduce(
  (acc, a) => {
    acc[a.gene] = [...(acc[a.gene] ?? []), a];
    return acc;
  },
  {} as Record<string, typeof anns>,
);

const homologs = (await fetchDrosophilaGenes(orthologousGenes)).map((gene) => ({
  ...gene,
  source: orthologySources[gene.id],
  annotations: annsById[gene.id],
}));

let linkTemplates: GeneLinkTemplate[] = [];

try {
  const items = await directus.request(readItems("gene_link_templates"));
  linkTemplates = items
    .map(({ label, template }) => ({
      label: label || "",
      template: template || "",
    }))
    .filter((link) => link.template.includes("{gene}"));
} catch (err) {
  console.error(" Error fetching gene link templates:", err);
}

if (!triboliumGene) {
  Astro.response.status = 404;
  Astro.response.statusText = "Not Found";
}
---

<style is:global>
  #jbrowse-linear-genome-view > div > div {
    background: transparent;
  }
  #jbrowse-linear-genome-view > div > div > div {
    box-shadow: none;
  }
</style>

<Layout>
  {
    triboliumGene ? (
      <GeneDetails
        gene={gene}
        linkTemplates={linkTemplates}
        triboliumGene={triboliumGene}
        dsRNAs={dsRNAs}
        phenotypes={phenotypes}
        homologs={homologs}
        client:load
      >
        <div slot="jbrowse-genome-view">
          <div id="jbrowse-styles-container" transition:persist></div>
          <JBrowseGenomeView
            triboliumGene={triboliumGene}
            client:only="react"
            transition:persist="jbrowse"
          />
        </div>
      </GeneDetails>
    ) : (
      <GeneNotFound />
    )
  }
</Layout>
